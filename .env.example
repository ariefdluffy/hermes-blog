# ── Database ───────────────────────────────────────────
DATABASE_URL="mysql://user:password@localhost:3306/hermes_blog"

# ── JWT ────────────────────────────────────────────────
# Wajib! Generate pake: openssl rand -hex 32
JWT_SECRET="change-me-to-random-64-char-hex-string"

# ── App ────────────────────────────────────────────────
PUBLIC_SITE_URL="https://lockbit.my.id"
PUBLIC_APP_URL="http://localhost:5173"
NODE_ENV="development"

# ── SMTP (email verification & reset password) ─────────
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# ── OpenAI / Hermes AI ─────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4"
OPENAI_BASE_URL="https://api.openai.com/v1"

# ── Hermes Agent API Key ───────────────────────────────
# Hash of API key for external agent authentication
# Generate: echo -n "salt+your-key" | sha256sum
HERMES_API_KEY_HASH=""
HERMES_API_KEY_SALT="change-me"
HERMES_API_KEY_SCOPE="write"
